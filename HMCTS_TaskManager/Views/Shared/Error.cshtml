@model ErrorViewModel

@{
  ViewData["Title"] = "Error";
}

<div class="text-center mt-5">

  <h1 class="text-danger mb-3">
    Task Manager error.
  </h1>

  <p class="lead mb-4">
    An unexpected error occured while processing your request.
  </p>

  <a asp-controller="Home"
     asp-action="Index"
     class="btn btn-primary">
    Return Home
  </a>

</div>