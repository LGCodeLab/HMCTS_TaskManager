@model IEnumerable<HMCTS_TaskManager.Models.TaskItem>
@using HMCTS_TaskManager.Constants

<h1 class="mb-4">Tasks Manager</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
  Create New Task
</a>

@if (!Model.Any())
{
  <div class="alert alert-info">
    No tasks found. Create your first task to get started.
  </div>
}
else
{
  <table class="table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Due Date</th>
        <th>Description</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      @foreach (var task in Model)
      {
        <tr>
          <td>@task.Title</td>

          <td>
            @if (task.Status == TaskStatuses.ToDo)
            {
              <span class="badge bg-secondary">ToDo</span>
            }
            else if (task.Status == TaskStatuses.InProgress)
            {
              <span class="badge bg-primary">InProgress</span>
            }
            else if (task.Status == TaskStatuses.Completed)
            {
              <span class="badge bg-success">Completed</span>
            }
          </td>

          <td>@task.DueDate.ToString("dd/MM/yyyy")</td>

          <td>
            @if (string.IsNullOrWhiteSpace(task.Description))
            {
              <span class="text-muted">No description provided.</span>
            }
            else
            {
              @task.Description
            }
          </td>

          <td>
            <a asp-action="Edit"
               asp-route-id="@task.Id"
               class="btn btn-sm btn-warning">
              Update Status
            </a>
            |
            <a asp-action="Delete"
               asp-route-id="@task.Id"
               class="btn btn-sm btn-danger">
              Delete
            </a>
          </td>
        </tr>
      }
    </tbody>
  </table>
}